{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "declaration": false,
    "outDir": ".tools-dist",
    "rootDir": ".",
    "noEmitOnError": true,
    "skipLibCheck": true
  },
  "include": [
    "scripts/**/*.ts",
    "test/**/*.ts"
  ]
}
